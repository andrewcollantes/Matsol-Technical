<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin — MSI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/admin/admin_account.css">
</head>
<body>

<aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
        <div class="brand-icon">
            <img src="/Image_Logo/MSI%20LOGO%20ORIGINAL%202%20(1)%20copy_edited.avif">
        </div>
        <span class="brand-name">MSI Admin</span>
    </div>

    <nav class="sidebar-nav">
        <button class="nav-item active" data-section="employees" onclick="switchSection('employees', this)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
            <span>Employees</span>
        </button>
        <button class="nav-item" data-section="clients" onclick="switchSection('clients', this)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
            <span>Clients</span>
        </button>
        <button class="nav-item" data-section="monitoring" onclick="switchSection('monitoring', this)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><rect x="7" y="11" width="3" height="6" rx="1"/><rect x="12" y="8" width="3" height="9" rx="1"/><rect x="17" y="5" width="3" height="12" rx="1"/></svg>
            <span>Monitoring</span>
        </button>
    </nav>

    <div class="sidebar-footer">
        <div class="admin-info">
            <div class="admin-avatar"><%= currentUser.fullName.charAt(0).toUpperCase() %></div>
            <div class="admin-details">
                <span class="admin-name"><%= currentUser.fullName %></span>
                <span class="admin-role"><%= currentUser.department %></span>
            </div>
        </div>
        <a href="/logout" class="logout-btn" title="Logout">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        </a>
    </div>
</aside>

<!-- MAIN CONTENT -->
<main class="main-content">

    <!-- FLASH MESSAGES -->
    <% if (success) { %>
        <div class="flash flash-success" id="flashMsg">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            <%= success %>
        </div>
    <% } %>
    <% if (error) { %>
        <div class="flash flash-error" id="flashMsg">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <%= error %>
        </div>
    <% } %>

    <!-- ── EMPLOYEES SECTION ── -->
    <section class="section active" id="section-employees">
        <div class="section-header">
            <div>
                <h1>Employee Accounts</h1>
                <p>Invite, update, and manage corporate user accounts.</p>
            </div>
            <button class="btn btn-primary" onclick="openModal('modal-invite-employee')">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                Invite Employee
            </button>
        </div>

        <!-- Stats Row -->
        <div class="stats-row">
            <div class="stat-chip">
                <span class="stat-num"><%= accounts.length %></span>
                <span class="stat-label">Total</span>
            </div>
            <div class="stat-chip">
                <span class="stat-num"><%= accounts.filter(a => a.status !== 'inactive').length %></span>
                <span class="stat-label">Active</span>
            </div>
            <div class="stat-chip">
                <span class="stat-num"><%= accounts.filter(a => a.status === 'inactive').length %></span>
                <span class="stat-label">Inactive</span>
            </div>
        </div>

        <!-- Employee Table Card -->
        <div class="card">
            <div class="card-toolbar">
                <div class="search-wrap">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    <input type="text" id="accountSearch" placeholder="Search name, department…" oninput="filterAccounts()">
                </div>
                <div class="filter-tabs">
                    <button class="filter-tab active" onclick="filterByStatus('all', this)">All</button>
                    <button class="filter-tab" onclick="filterByStatus('active', this)">Active</button>
                    <button class="filter-tab" onclick="filterByStatus('inactive', this)">Inactive</button>
                </div>
            </div>

            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Employee</th>
                            <th>Username</th>
                            <th>Department</th>
                            <th>Branch</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="accountTableBody">
                        <% accounts.forEach((account, index) => { %>
                        <tr class="emp-row" data-status="<%= account.status === 'inactive' ? 'inactive' : 'active' %>">
                            <td><%= index + 1 %></td>
                            <td>
                                <div class="person-cell">
                                    <div class="avatar-sm"><%= account.fullName.charAt(0).toUpperCase() %></div>
                                    <span><%= account.fullName %></span>
                                </div>
                            </td>
                            <td><code class="mono"><%= account.username %></code></td>
                            <td><%= account.department %></td>
                            <td><%= account.branch %></td>
                            <td>
                                <% if (account.status === 'inactive') { %>
                                    <span class="badge badge-inactive">Inactive</span>
                                <% } else { %>
                                    <span class="badge badge-active">Active</span>
                                <% } %>
                            </td>
                            <td>
                                <div class="action-btns">
                                    <button class="icon-btn icon-edit" title="Edit"
                                        onclick="openEditEmployee('<%= account.username %>', '<%= account.fullName %>', '<%= account.department %>', '<%= account.branch %>')">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                    </button>
                                    <button class="icon-btn icon-key" title="Reset Password"
                                        onclick="openResetPass('<%= account.username %>')">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                                    </button>
                                    <% if (account.status === 'inactive') { %>
                                    <button class="icon-btn icon-enable" title="Reactivate"
                                        onclick="toggleEmployee('<%= account.username %>', 'active')">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                                    </button>
                                    <% } else { %>
                                    <button class="icon-btn icon-disable" title="Deactivate"
                                        onclick="toggleEmployee('<%= account.username %>', 'inactive')">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                                    </button>
                                    <% } %>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <!-- ── CLIENTS SECTION ── -->
    <section class="section" id="section-clients">
        <div class="section-header">
            <div>
                <h1>Client Management</h1>
                <p>Add, update, and toggle client partnership status.</p>
            </div>
            <button class="btn btn-primary" onclick="openModal('modal-create-client')">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                New Client
            </button>
        </div>

        <!-- Stats Row -->
        <div class="stats-row">
            <div class="stat-chip">
                <span class="stat-num"><%= clients.length %></span>
                <span class="stat-label">Total</span>
            </div>
            <div class="stat-chip">
                <span class="stat-num"><%= clients.filter(c => c.status !== 'inactive').length %></span>
                <span class="stat-label">Active</span>
            </div>
            <div class="stat-chip">
                <span class="stat-num"><%= clients.filter(c => c.status === 'inactive').length %></span>
                <span class="stat-label">Inactive</span>
            </div>
        </div>

        <div class="card">
            <div class="card-toolbar">
                <div class="search-wrap">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    <input type="text" id="clientSearch" placeholder="Search client, location…" oninput="filterClients()">
                </div>
                <div class="filter-tabs">
                    <button class="filter-tab active" onclick="filterClientsByStatus('all', this)">All</button>
                    <button class="filter-tab" onclick="filterClientsByStatus('active', this)">Active</button>
                    <button class="filter-tab" onclick="filterClientsByStatus('inactive', this)">Inactive</button>
                </div>
            </div>

            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Client Name</th>
                            <th>Location</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="clientTableBody">
                        <% clients.forEach((client, index) => { %>
                        <tr class="cli-row" data-status="<%= client.status === 'inactive' ? 'inactive' : 'active' %>">
                            <td><%= index + 1 %></td>
                            <td>
                                <div class="person-cell">
                                    <div class="avatar-sm avatar-client"><%= client.name.charAt(0).toUpperCase() %></div>
                                    <span><%= client.name %></span>
                                </div>
                            </td>
                            <td><%= client.location || '—' %></td>
                            <td>
                                <% if (client.status === 'inactive') { %>
                                    <span class="badge badge-inactive">Inactive</span>
                                <% } else { %>
                                    <span class="badge badge-active">Active</span>
                                <% } %>
                            </td>
                            <td>
                                <div class="action-btns">
                                    <button class="icon-btn icon-edit" title="Edit"
                                        onclick="openEditClient('<%= client.id %>', '<%= client.name %>', '<%= client.location %>')">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                    </button>
                                    <% if (client.status === 'inactive') { %>
                                    <button class="icon-btn icon-enable" title="Reactivate"
                                        onclick="toggleClient('<%= client.id %>', 'active')">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                                    </button>
                                    <% } else { %>
                                    <button class="icon-btn icon-disable" title="Deactivate"
                                        onclick="toggleClient('<%= client.id %>', 'inactive')">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                                    </button>
                                    <% } %>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <!-- ── MONITORING SECTION ── -->
    <section class="section" id="section-monitoring">
        <div class="section-header monitor-section-header">
            <div>
                <h1>Monitoring Overview</h1>
                <p>Live operational view from client machine activity and service records.</p>
            </div>
            <div class="monitor-range-wrap">
                <label for="monitorDateRange" class="monitor-range-label">Show data for</label>
                <select id="monitorDateRange" class="monitor-select monitor-range-select" onchange="onMonitorRangeChange(this.value)">
                    <option value="all" selected>All Time</option>
                    <option value="this-month">This Month</option>
                    <option value="last-month">Last Month</option>
                    <option value="last-year">Last Year</option>
                </select>
            </div>
        </div>

        <div class="stats-row monitor-kpis" id="monitorKpiRow">
            <div class="stat-chip stat-chip-clickable" data-kpi="pendingUnits" onclick="openKpiDetail('pendingUnits')" title="Click to see details">
                <span class="stat-num" id="kpi-pendingUnits"><%= monitoring.pendingUnits %></span>
                <span class="stat-label">Pending Units</span>
            </div>
            <div class="stat-chip stat-chip-clickable" data-kpi="pendingClients" onclick="openKpiDetail('pendingClients')" title="Click to see details">
                <span class="stat-num" id="kpi-pendingClients"><%= monitoring.pendingClientsList.length %></span>
                <span class="stat-label">Clients Pending</span>
            </div>
            <div class="stat-chip stat-chip-clickable" data-kpi="techReports" onclick="openKpiDetail('techReports')" title="Click to see details">
                <span class="stat-num" id="kpi-techReports"><%= monitoring.reportEvents + monitoring.updateEvents %></span>
                <span class="stat-label">Tech Reports Log</span>
            </div>
            <div class="stat-chip stat-chip-clickable" data-kpi="completionRate" onclick="openKpiDetail('completionRate')" title="Click to see details">
                <span class="stat-num" id="kpi-completionRate"><%= monitoring.completionRate %>%</span>
                <span class="stat-label">Completion Rate</span>
            </div>
        </div>


        <div class="monitor-grid">
            <article class="card monitor-card monitor-card-emphasis">
                <header class="monitor-card-head">
                    <h3>Status Distribution</h3>
                    <small><%= monitoring.totalUnits %> tracked units</small>
                </header>
                <div class="status-split">
                    <div class="status-ring" style="--pct:<%= monitoring.completionRate %>">
                        <div class="status-ring-inner">
                            <strong><%= monitoring.completionRate %>%</strong>
                            
                        </div>
                    </div>
                    <div class="status-bars">
                        <% if (!monitoring.statusShare.length) { %>
                            <p class="monitor-empty">No status data yet.</p>
                        <% } %>
                        <% monitoring.statusShare.forEach(row => { %>
                            <div class="status-row">
                                <div class="status-row-head">
                                    <span><%= row.label %></span>
                                    <small><%= row.count %> (<%= row.percentage %>%)</small>
                                </div>
                                <div class="status-track">
                                    <span class="status-fill" style="width:<%= row.percentage %>%"></span>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </article>

            <article class="card monitor-card monitor-card-half monitor-scroll-card">
                <header class="monitor-card-head">
                    <h3>Client Unit Progress</h3>
                    <small>Warning-free unit completion per client</small>
                </header>
                <div class="client-highlight-list monitor-scroll-body" id="clientHighlightList">
                    <% if (!monitoring.clientHighlights.length) { %>
                        <p class="monitor-empty">No client progress available yet.</p>
                    <% } %>
                    <% monitoring.clientHighlights.forEach(client => { %>
                        <div class="client-highlight-row client-highlight-clickable"
                             onclick="openClientDetail('<%= client.clientName %>', <%= client.units %>, <%= client.finishedUnits %>, <%= client.reports %>, <%= client.updates %>, <%= client.completionRate %>, <%= client.isActive %>)"
                             title="Click to view client details">
                            <div>
                                <strong><%= client.clientName %></strong>
                                <small><%= client.isActive ? 'Active client' : 'Inactive client' %></small>
                            </div>
                            <div class="client-highlight-meta">
                                <span><%= client.finishedUnits %>/<%= client.units %> units</span>
                                <span><%= client.reports %> reports</span>
                                <span class="score-pill"><%= client.completionRate %>%</span>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </article>

            <article class="card monitor-card monitor-card-wide monitor-scroll-card">
                <header class="monitor-card-head">
                    <div>
                        <h3>Technician Activity Log</h3>
                        <small>
                            <%= monitoring.activityRowTotal != null ? monitoring.activityRowTotal : monitoring.activityRows.length %> technician actions recorded
                            <% if (monitoring.activityRowsCapped) { %>
                                (showing newest <%= monitoring.activityRows.length %> — set MONITOR_ACTIVITY_ROW_CAP=0 on the server for all rows; may be slower)
                            <% } %>
                        </small>
                    </div>
                    <small>Filter by technician, client, unit, model, installed records, maintenance, or parts, then export the visible rows to CSV.</small>
                </header>

                <div class="monitor-toolbar">
                    <div class="monitor-controls">
                        <select id="monitorTechnicianFilter" class="monitor-select" onchange="applyMonitoringFilters()">
                            <option value="">All technicians</option>
                            <% monitoring.technicianOptions.forEach(name => { %>
                                <option value="<%= name %>"><%= name %></option>
                            <% }) %>
                        </select>

                        <select id="monitorClientFilter" class="monitor-select" onchange="applyMonitoringFilters()">
                            <option value="">All clients</option>
                            <% monitoring.clientOptions.forEach(name => { %>
                                <option value="<%= name %>"><%= name %></option>
                            <% }) %>
                        </select>

                        <select id="monitorUnitFilter" class="monitor-select" onchange="applyMonitoringFilters()">
                            <option value="">All units</option>
                            <% monitoring.unitOptions.forEach(name => { %>
                                <option value="<%= name %>"><%= name %></option>
                            <% }) %>
                        </select>

                        <select id="monitorModelFilter" class="monitor-select" onchange="applyMonitoringFilters()">
                            <option value="">All models</option>
                        </select>

                        <select id="monitorTypeFilter" class="monitor-select" onchange="applyMonitoringFilters()">
                            <option value="">All activity</option>
                            <option value="installed">Unit Installed</option>
                            <option value="maintenance">Maintenance</option>
                            <option value="parts">Parts Change</option>
                        </select>

                        <select id="monitorSortFilter" class="monitor-select" onchange="sortMonitoringRows()">
                            <option value="date-desc">Sort by date (newest first)</option>
                            <option value="date-asc">Sort by date (oldest first)</option>
                            <option value="technician-asc">Sort by technician (A-Z)</option>
                            <option value="technician-desc">Sort by technician (Z-A)</option>
                            <option value="client-asc">Sort by client (A-Z)</option>
                            <option value="client-desc">Sort by client (Z-A)</option>
                        </select>
                    </div>

                    <button type="button" class="btn btn-primary monitor-export-btn" onclick="exportMonitoringCsv()">
                        Export CSV
                    </button>
                </div>

                <div class="monitor-results">
                    <small>Current selection</small>
                    <span class="monitor-results-count" id="monitorResultsCount"><%= monitoring.activityRows.length %> of <%= monitoring.activityRowTotal != null ? monitoring.activityRowTotal : monitoring.activityRows.length %></span>
                </div>

                <div class="monitor-no-results" id="monitorNoResults" hidden>No matching technician activity was found for the selected filters.</div>

                <div class="table-wrap monitor-scroll-body">
                    <table id="monitorActivityTable">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Technician</th>
                                <th>Client</th>
                                <th>Unit</th>
                                <th>Model</th>
                                <th>Activity</th>
                                <th>Parts Affected</th>
                                <th>Details</th>
                            </tr>
                        </thead>
                        <tbody id="monitorActivityBody">
                            <% if (!monitoring.activityRows.length) { %>
                                <tr>
                                    <td colspan="8" class="monitor-empty-state">No technician activity recorded yet.</td>
                                </tr>
                            <% } %>
                            <% monitoring.activityRows.forEach((row, index) => { %>
                                <tr
                                    class="monitor-row"
                                    data-date-sort="<%= row.dateSort %>"
                                    data-technician="<%= row.technicianSort || row.technician %>"
                                    data-technicians="<%= row.technician %>"
                                    data-submitted-by="<%= row.submittedBy || row.technician %>"
                                    data-technicians-text="<%= row.techniciansText || row.technician %>"
                                    data-client="<%= row.clientName %>"
                                    data-unit="<%= row.unitName %>"
                                    data-model="<%= row.modelName %>"
                                    data-serial-no="<%= row.serialNo || '' %>"
                                    data-running-hours="<%= row.runningHours || 0 %>"
                                    data-type="<%= row.activityKind %>"
                                    data-activity-tags="<%= Array.isArray(row.activityTags) ? row.activityTags.join(',') : row.activityKind %>"
                                    data-status="<%= row.machineStatus.toLowerCase() %>"
                                    data-description="<%= row.description || '' %>"
                                    data-problem="<%= row.problem || '' %>"
                                    data-action="<%= row.action || '' %>"
                                    data-recommendation="<%= row.recommendation || '' %>"
                                    data-maintenance-summary="<%= row.maintenanceSummary || '' %>"
                                    data-parts-csv="<%= row.partsCsv || '' %>"
                                    data-row-index="<%= index %>"
                                >
                                    <td class="monitor-date"><%= row.dateLabel %></td>
                                    <td>
                                        <div class="monitor-cell-stack">
                                            <strong><%= row.technician %></strong>
                                            <small><%= row.sourceLabel %> • <%= row.machineStatus %></small>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="monitor-cell-stack">
                                            <strong><%= row.clientName %></strong>
                                            <small><%= row.serialNo %></small>
                                        </div>
                                    </td>
                                    <td><%= row.unitName %></td>
                                    <td><%= row.modelName %></td>
                                    <td><span class="monitor-type-pill"><%= row.activityLabel %></span></td>
                                    <td class="monitor-parts-list"><%= row.partsLabel %></td>
                                    <td class="monitor-parts-list"><%= row.details %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </article>
        </div>
    </section>

</main>

<!-- ══════════════════════════════════════════
     MODALS
═══════════════════════════════════════════ -->

<!-- Modal: Invite Employee -->
<div class="modal-overlay" id="modal-invite-employee" onclick="closeOnOverlay(event, 'modal-invite-employee')">
    <div class="modal">
        <div class="modal-header">
            <h3>Send Account Invite</h3>
            <button type="button" class="modal-close" onclick="closeModal('modal-invite-employee')">×</button>
        </div>
        <form action="/admin_account/employees/invite" method="POST">
            <div class="modal-body">
                <p class="modal-desc">
                    Enter the recipient's email and details. They will receive a secure one-time link to set up their own username and password.
                </p>
                <div class="form-group">
                    <label>Email Address</label>
                    <input type="email" name="inviteEmail" placeholder="employee@msi.com" required autocomplete="off">
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Role</label>
                        <select name="inviteRole" required>
                            <option value="">Select Role</option>
                            <option value="employee">Employee</option>
                            <option value="admin">Admin</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Branch</label>
                        <select name="inviteBranch" required>
                            <option value="">Select Branch</option>
                            <option value="Silang">Silang</option>
                            <option value="Davao">Davao</option>
                            <option value="Cebu">Cebu</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label>Department</label>
                    <input type="text" name="inviteDept" id="inviteDeptInput" placeholder="e.g. ENGINEERING" required>
                    <small>Invite link expires in 24 hours.</small>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeModal('modal-invite-employee')">Cancel</button>
                <button type="submit" class="btn btn-primary">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                    Send Invite
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Modal: Edit Employee -->
<div class="modal-overlay" id="modal-edit-employee" onclick="closeOnOverlay(event, 'modal-edit-employee')">
    <div class="modal">
        <div class="modal-header">
            <h3>Edit Employee</h3>
            <button type="button" class="modal-close" onclick="closeModal('modal-edit-employee')">×</button>
        </div>
        <form action="/admin_account/employees/update" method="POST">
            <input type="hidden" name="username" id="editEmpUsername">
            <div class="modal-body">
                <div class="form-group">
                    <label>Full Name</label>
                    <input type="text" name="fullName" id="editEmpFullName"
                        pattern="^[A-Za-z\s]+$" title="Letters and spaces only" required>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Department</label>
                        <input type="text" name="department" id="editEmpDept" required>
                    </div>
                    <div class="form-group">
                        <label>Branch</label>
                        <select name="branch" id="editEmpBranch" required>
                            <option value="Silang">Silang</option>
                            <option value="Davao">Davao</option>
                            <option value="Cebu">Cebu</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeModal('modal-edit-employee')">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<!-- Modal: Reset Password -->
<div class="modal-overlay" id="modal-reset-pass" onclick="closeOnOverlay(event, 'modal-reset-pass')">
    <div class="modal modal-sm">
        <div class="modal-header">
            <h3>Send Reset Link</h3>
            <button type="button" class="modal-close" onclick="closeModal('modal-reset-pass')">×</button>
        </div>
        <form action="/admin_account/employees/reset-password" method="POST">
            <input type="hidden" name="username" id="resetPassUsername">
            <div class="modal-body">
                <p class="modal-desc">Send a secure password reset link for: <strong id="resetPassDisplay"></strong></p>
                <div class="form-group">
                    <label>Email Address</label>
                    <input
                        type="email"
                        name="resetEmail"
                        placeholder="employee@msi.com"
                        pattern="^(?=.{1,254}$)(?=.{1,64}@)[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}$"
                        maxlength="254"
                        required
                    >
                    <small>Employee will receive a one-time link to create a new password.</small>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeModal('modal-reset-pass')">Cancel</button>
                <button type="submit" class="btn btn-primary">Send Reset Link</button>
            </div>
        </form>
    </div>
</div>

<!-- Hidden form: Toggle Employee Status -->
<form id="form-toggle-emp" action="/admin_account/employees/toggle" method="POST" style="display:none">
    <input type="hidden" name="username" id="toggleEmpUsername">
    <input type="hidden" name="status"   id="toggleEmpStatus">
</form>

<!-- Modal: Create Client -->
<div class="modal-overlay" id="modal-create-client" onclick="closeOnOverlay(event, 'modal-create-client')">
    <div class="modal modal-sm">
        <div class="modal-header">
            <h3>Add New Client</h3>
            <button class="modal-close" onclick="closeModal('modal-create-client')">×</button>
        </div>
        <form action="/admin_account/clients/create" method="POST">
            <div class="modal-body">
                <div class="form-group">
                    <label>Client Name</label>
                    <input type="text" name="clientName" placeholder="Acme Corp" required>
                </div>
                <div class="form-group">
                    <label>Location</label>
                    <input type="text" name="location" placeholder="Manila">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeModal('modal-create-client')">Cancel</button>
                <button type="submit" class="btn btn-primary">Add Client</button>
            </div>
        </form>
    </div>
</div>

<!-- Modal: Edit Client -->
<div class="modal-overlay" id="modal-edit-client" onclick="closeOnOverlay(event, 'modal-edit-client')">
    <div class="modal modal-sm">
        <div class="modal-header">
            <h3>Edit Client</h3>
            <button class="modal-close" onclick="closeModal('modal-edit-client')">×</button>
        </div>
        <form action="/admin_account/clients/update" method="POST">
            <input type="hidden" name="clientId" id="editClientId">
            <div class="modal-body">
                <div class="form-group">
                    <label>Client Name</label>
                    <input type="text" name="clientName" id="editClientName" required>
                </div>
                <div class="form-group">
                    <label>Location</label>
                    <input type="text" name="location" id="editClientLocation">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeModal('modal-edit-client')">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<!-- Hidden form: Toggle Client Status -->
<form id="form-toggle-cli" action="/admin_account/clients/toggle" method="POST" style="display:none">
    <input type="hidden" name="clientId" id="toggleCliId">
    <input type="hidden" name="status"   id="toggleCliStatus">
</form>

<!-- Modal: KPI Detail -->
<div class="modal-overlay" id="modal-kpi-detail" onclick="closeOnOverlay(event, 'modal-kpi-detail')">
    <div class="modal modal-kpi">
        <div class="modal-header">
            <h3 id="kpiDetailTitle">KPI Detail</h3>
            <button type="button" class="modal-close" onclick="closeModal('modal-kpi-detail')">×</button>
        </div>
        <div class="modal-body">
            <div id="kpiDetailContent" class="kpi-detail-content">
                <p class="monitor-empty">Loading…</p>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Client Detail -->
<div class="modal-overlay" id="modal-client-detail" onclick="closeOnOverlay(event, 'modal-client-detail')">
    <div class="modal modal-kpi">
        <div class="modal-header">
            <h3 id="clientDetailTitle">Client Detail</h3>
            <button type="button" class="modal-close" onclick="closeModal('modal-client-detail')">×</button>
        </div>
        <div class="modal-body">
            <div id="clientDetailContent" class="kpi-detail-content">
                <p class="monitor-empty">Loading…</p>
            </div>
        </div>
    </div>
</div>

<script>
    window.monitoringUnitModelOptions = <%- JSON.stringify(monitoring.unitModelOptions || {}) %>;
    window.monitoringModelOptions = <%- JSON.stringify(monitoring.modelOptions || []) %>;
    window.monitoringInitData = <%- JSON.stringify({
        completedUnits: monitoring.completedUnits,
        pendingUnits: monitoring.pendingUnits,
        completedClients: monitoring.completedClients,
        pendingClientsList: monitoring.pendingClientsList,
        reportEvents: monitoring.reportEvents,
        updateEvents: monitoring.updateEvents,
        completionRate: monitoring.completionRate,
        totalUnits: monitoring.totalUnits,
        statusShare: monitoring.statusShare,
        clientHighlights: monitoring.clientHighlights,
        techReports: monitoring.techReports
    }) %>;
</script>
<script src="/js/admin/admin_account.js?v=<%= Date.now() %>"></script>
</body>
</html>
